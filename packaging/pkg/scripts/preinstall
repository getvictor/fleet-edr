#!/bin/sh
# Pre-install script for Fleet EDR.
#
# Runs before pkg payload is laid down. On upgrade, stops the running agent
# cleanly so we can overwrite /usr/local/bin/fleet-edr-agent without busy-file
# errors. On fresh installs it is a no-op.
#
# Never fails hard: any single step can miss (e.g. no LaunchDaemon yet on a
# fresh install) without blocking the rest of the installer.

set -e

LABEL=com.fleetdm.edr.agent
PLIST=/Library/LaunchDaemons/${LABEL}.plist

# Stop + unload the LaunchDaemon if it exists. `bootout` replaces the
# deprecated `unload`; both return non-zero when the target is not loaded, so
# we swallow the exit code.
if [ -f "$PLIST" ]; then
    /bin/launchctl bootout system "$PLIST" 2>/dev/null || true
fi

# Boot the activation LaunchAgent out of the console user's GUI session so an
# upgrade doesn't replace the app bundle under a running activate. No-op on
# fresh installs and at the loginwindow.
ACTIVATE_LA=/Library/LaunchAgents/com.fleetdm.edr.activate.plist
CONSOLE_UID=$(/usr/bin/stat -f %u /dev/console 2>/dev/null || echo 0)
if [ -f "$ACTIVATE_LA" ] && [ "$CONSOLE_UID" -gt 0 ]; then
    /bin/launchctl bootout "gui/$CONSOLE_UID" "$ACTIVATE_LA" 2>/dev/null || true
fi

# The system extension is NOT deactivated on upgrade: the post-upgrade activation LaunchAgent re-runs `edr activate`,
# and the host app replaces the existing extension with the new bundle (OSSystemExtensionRequest .replace). Deactivating
# here would needlessly tear telemetry down and force a reboot. (The previous `systemextensionsctl deactivate` call here
# was a no-op anyway: systemextensionsctl has no `deactivate` subcommand.)

exit 0
