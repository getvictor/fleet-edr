# Build contexts for every image in this repo.
# The server Dockerfile lives in server/ but runs with the repo root as its
# build context so it can pull in internal/envparse (referenced via go.work).
# Keep this list tight because every ignored entry skips stat + hash work on
# every `docker build`.

# Local scratch + logs.
tmp/
claude/
.DS_Store

# Test caches.
**/testdata/output/
**/*.test

# Toolchain + IDE state.
.idea/
.vscode/
.claude/
*.iml

# Agent binary artifacts (not needed for the server image).
agent/cmd/*/dist/
agent/cmd/m3-queue-stuffer/

# Xcode build outputs (very large).
extension/edr/build/
extension/edr/DerivedData/
extension/edr/*.xcworkspace/xcuserdata/
extension/edr/*.xcodeproj/xcuserdata/
extension/edr/*.xcodeproj/project.xcworkspace/xcuserdata/

# Provisioning profiles are not needed by the server image (agent-side).
packaging/provisioning/

# UI: the ui-build stage in server/Dockerfile runs `npm ci && npm run build`
# and writes to /src/server/ui/dist inside the container. We don't need the
# host's server/ui/dist in the build context — that would just waste time
# stat'ing files we're about to overwrite. The previous instance of this
# list left server/ui/dist IN because the single-stage Dockerfile relied on
# the operator pre-building locally; the multi-stage build makes that
# unnecessary.
ui/node_modules/
ui/dist/
server/ui/dist/

# VCS.
.git/
.github/
