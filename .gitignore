/ai
tmp
.claude/scheduled_tasks.lock

# Per-topic scratch plans (e.g. claude/mvp/plan.md). The .dockerignore,
# sonar-project.properties, and the maintenance task docs all assume
# this tree stays out of the committed repo; this rule keeps the
# project state aligned with that convention.
claude/

# Xcode
xcuserdata/
*.xcuserstate
DerivedData/
build/

# IDEs
.idea/

# Node / UI
/ui/node_modules/

# UI build output (embedded via server/ui/embed.go)
/server/ui/dist/

# Release-build output: signed pkg + signed profiles + checksums.
# Regenerated on every `packaging/pkg/build.sh` run; never committed.
/dist/

# Coverage artifacts written by the `task test:go:*:coverage` tasks and
# the CI Sonar scan job. Regenerated on every run; never committed.
/coverage-agent.out
/coverage-server.out
/ui/coverage/
# Taskfile.dev temp cache
.task/
