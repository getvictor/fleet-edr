/ai
tmp
.claude/scheduled_tasks.lock

# Xcode
xcuserdata/
*.xcuserstate
DerivedData/
build/

# SwiftPM (extension/edr/Package.swift, used for `swift test` on extension Swift sources)
.build/
.swiftpm/
Package.resolved

# IDEs
.idea/

# Node / UI
/ui/node_modules/

# UI build output (embedded via server/ui/embed.go)
/server/ui/dist/

# Root-level Go binaries: `go build` from the repo root drops them next
# to go.mod and they don't belong in version control. The release pipeline
# writes to /dist/ instead (see below).
/fleet-edr-server
/fleet-edr-agent

# Release-build output: signed pkg + signed profiles + checksums.
# Regenerated on every `packaging/pkg/build.sh` run; never committed.
/dist/

# Coverage artifacts written by the `task test:go:*:coverage` tasks,
# `task test:e2e:coverage`, and the CI Sonar scan job. Regenerated on
# every run; never committed.
/coverage-agent.out
/coverage-server.out
/coverage-server-e2e.out
/ui/coverage/
/test/e2e/coverage/
/test/e2e/coverage-raw/
# Taskfile.dev temp cache
.task/
