{
  "version": "v5",
  "title": "EDR HTTP server (RED)",
  "description": "Rate, errors, and latency for the EDR server's HTTP API. Import via SigNoz: Dashboards -> New dashboard -> Import JSON. Requires the server to export OTLP with service.name=fleet-edr-server.",
  "tags": ["edr", "http", "red"],
  "uploadedGrafana": false,
  "panelMap": {},
  "variables": {
    "environment": {
      "id": "environment",
      "name": "environment",
      "description": "Deployment environment to view, auto-discovered from the deployment.environment resource attribute. The fleet-edr server always emits deployment.environment (default value 'default', overridable via OTEL_RESOURCE_ATTRIBUTES) so this key exists in every SigNoz instance it reports to, which makes the dynamic lookup safe. Defaults to ALL so all environments show.",
      "type": "DYNAMIC",
      "dynamicVariablesAttribute": "deployment.environment",
      "dynamicVariablesSource": "Metrics",
      "customValue": "",
      "queryValue": "",
      "textboxValue": "",
      "multiSelect": true,
      "showALLOption": true,
      "sort": "ASC",
      "selectedValue": "__all__",
      "allSelected": true,
      "order": 0
    }
  },
  "layout": [
    { "i": "req-rate-route", "x": 0, "y": 0, "w": 6, "h": 4, "moved": false, "static": false },
    { "i": "err-rate-5xx", "x": 6, "y": 0, "w": 6, "h": 4, "moved": false, "static": false },
    { "i": "dur-p95", "x": 0, "y": 4, "w": 6, "h": 4, "moved": false, "static": false },
    { "i": "dur-p99", "x": 6, "y": 4, "w": 6, "h": 4, "moved": false, "static": false },
    { "i": "rate-by-status", "x": 0, "y": 8, "w": 6, "h": 4, "moved": false, "static": false },
    { "i": "rate-by-method", "x": 6, "y": 8, "w": 6, "h": 4, "moved": false, "static": false }
  ],
  "widgets": [
    {
      "id": "req-rate-route",
      "title": "Request rate by route (R)",
      "description": "Per-second request throughput from the histogram observation count, grouped by route template. The high-frequency POST /api/events ingest path dominates; a sudden change in its rate is the fleet's heartbeat.",
      "panelTypes": "graph",
      "yAxisUnit": "cps",
      "legendPosition": "bottom",
      "contextLinks": { "linksData": [] },
      "selectedLogFields": [],
      "selectedTracesFields": [],
      "thresholds": [],
      "query": {
        "queryType": "builder",
        "promql": [],
        "clickhouse_sql": [],
        "builder": {
          "queryFormulas": [],
          "queryData": [
            {
              "queryName": "A",
              "dataSource": "metrics",
              "expression": "A",
              "stepInterval": 0,
              "aggregations": [
                {
                  "metricName": "http.server.request.duration.count",
                  "temporality": "Cumulative",
                  "timeAggregation": "rate",
                  "spaceAggregation": "sum"
                }
              ],
              "filter": { "expression": "service.name = 'fleet-edr-server' AND deployment.environment IN $environment" },
              "groupBy": [{ "key": "http.route", "dataType": "string", "type": "tag" }],
              "legend": "{{http.route}}",
              "functions": [],
              "having": { "expression": "" },
              "orderBy": [],
              "selectColumns": []
            }
          ]
        }
      }
    },
    {
      "id": "err-rate-5xx",
      "title": "Error rate: 5xx by route (E)",
      "description": "Per-second rate of server-error (5xx) responses, grouped by route. The access log's old WARN lines turned into a metric: any sustained non-zero series is a route that is failing. Pair with the status-code panel to separate server faults from client/auth rejections.",
      "panelTypes": "graph",
      "yAxisUnit": "cps",
      "legendPosition": "bottom",
      "contextLinks": { "linksData": [] },
      "selectedLogFields": [],
      "selectedTracesFields": [],
      "thresholds": [],
      "query": {
        "queryType": "builder",
        "promql": [],
        "clickhouse_sql": [],
        "builder": {
          "queryFormulas": [],
          "queryData": [
            {
              "queryName": "A",
              "dataSource": "metrics",
              "expression": "A",
              "stepInterval": 0,
              "aggregations": [
                {
                  "metricName": "http.server.request.duration.count",
                  "temporality": "Cumulative",
                  "timeAggregation": "rate",
                  "spaceAggregation": "sum"
                }
              ],
              "filter": { "expression": "service.name = 'fleet-edr-server' AND http.response.status_code >= 500 AND deployment.environment IN $environment" },
              "groupBy": [{ "key": "http.route", "dataType": "string", "type": "tag" }],
              "legend": "{{http.route}}",
              "functions": [],
              "having": { "expression": "" },
              "orderBy": [],
              "selectColumns": []
            }
          ]
        }
      }
    },
    {
      "id": "dur-p95",
      "title": "Duration p95 by route (D)",
      "description": "95th-percentile request latency per route, in seconds, computed from the histogram buckets. The access-log slow-warn threshold is 500ms; a route whose p95 climbs toward that is the regression to chase before it starts emitting WARN lines.",
      "panelTypes": "graph",
      "yAxisUnit": "s",
      "legendPosition": "bottom",
